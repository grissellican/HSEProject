# CLOUDFLARE_ACCOUNT_ID=tu_account_id_de_cloudflare
# AWS_ACCESS_KEY_ID=tu_access_key
# AWS_SECRET_ACCESS_KEY=tu_secret_key
# AWS_STORAGE_BUCKET_NAME=nombre_de_tu_bucket
# AWS_S3_CUSTOM_DOMAIN=tu-dominio-personalizado.com (Opcional, para URLs públicas directas)


# ==========================================
# Configuración del Administrador (Seed)
# ==========================================
# Se utilizan al ejecutar el script seed.py para crear el primer usuario administrador
